# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/calendar-du-duck?sslmode=require

# Family Configuration
# Copy this file to .env.local and customize with your family's names.
# .env.local is gitignored and will never be committed.

NEXT_PUBLIC_PARENT_A_NAME=Papa
NEXT_PUBLIC_PARENT_B_NAME=Maman
NEXT_PUBLIC_CHILD_A_NAME=Enfant 1
NEXT_PUBLIC_CHILD_B_NAME=Enfant 2

# Custom images (optional - defaults to SVG placeholders)
# Use local paths (/images/parent-a.jpg) or external URLs
# NEXT_PUBLIC_IMAGE_PARENT_A=/images/parent-a.jpg
# NEXT_PUBLIC_IMAGE_PARENT_B=/images/parent-b.jpg
# NEXT_PUBLIC_IMAGE_PLANNING_CHILD_A=/images/planning-child-a.jpg
# NEXT_PUBLIC_IMAGE_PLANNING_CHILD_B=/images/planning-child-b.jpg
